{
  "expo": {
    "name": "MixMate",
    "slug": "mixmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0F0A1E"
    },
    "android": {
      "package": "com.mixmate.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0F0A1E"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mixmate.app"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "scheme": "mixmate",
    "experiments": {
      "typedRoutes": true
    }
  }
}
